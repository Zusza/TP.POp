    class Konsola : Kronikarz
    {
        public void ZapiszWydarzenie(string w)
        {
            Console.WriteLine(w);
        }
    }
    class DoPliku : Kronikarz
    {
        public void ZapiszWydarzenie(string w)
        {
            File.AppendAllText("../../plik.txt", w);
