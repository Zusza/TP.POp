    class Wiadomosc
    {
        Kronikarz kronikarz;
        Archiwista archiwista;

        public Wiadomosc(Kronikarz kro, Archiwista arc)
        {
            kronikarz = kro;
            archiwista = arc;
        }

        public string Tytul;
        public string Wiado;

        public void zapiszWiado(string tytul, string wiado)
        {
            Tytul = tytul;
            Wiado = wiado;

            string zapi = $"Tytuł: {tytul}, Wiadomość: {wiado}";

            kronikarz.ZapiszWydarzenie(zapi);
            archiwista.ZapiszDluzej(zapi);
        }
    }
    internal class Program
    {
        static void Main(string[] args)
        {
            Wiadomosc wiadomosc = new Wiadomosc(new Konsola(), new BazaDanych());
            wiadomosc.zapiszWiado("Tytuł1", "Bajo jajo");
